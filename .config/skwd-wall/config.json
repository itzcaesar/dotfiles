{
  "compositor": "niri",
  "monitor": "",
  "general": {
    "locale": "",
    "closeOnSelection": false,
    "reopenAtLastSelection": false
  },
  "paths": {
    "wallpaper": "~/Pictures/Wallpapers",
    "videoWallpaper": "~/videowalls",
    "cache": "",
    "templates": "",
    "scripts": "",
    "steam": "",
    "steamWorkshop": "",
    "steamWeAssets": ""
  },
  "features": {
    "matugen": true,
    "ollama": false,
    "steam": false,
    "wallhaven": true
  },
  "colorSource": "magick",
  "ollama": {
    "url": "http://localhost:11434",
    "model": "gemma3:4b",
    "consolidateEnabled": true
  },
  "steam": {
    "apiKey": "",
    "username": ""
  },
  "wallhaven": {
    "apiKey": ""
  },
  "matugen": {
    "schemeType": "scheme-content",
    "mode": "dark"
  },
  "integrations": [
    {
      "_comment": "Built-in: MD3 colors for the shell UI (always needed)",
      "name": "skwd-wall",
      "template": "quickshell-colors.json",
      "output": "colors.json"
    },
    {
      "_comment": "MD3 colors for the Skwd shell widgets (skwd-bar etc)",
      "name": "skwd",
      "template": "quickshell-colors.json",
      "output": "~/.cache/skwd/colors.json"
    },
    {
      "name": "kitty",
      "template": "kitty.conf",
      "output": "~/.config/kitty/skwd-theme.conf",
      "reload": "pkill -USR1 kitty"
    },
    {
      "name": "spicetify-css",
      "template": "spicetify.css",
      "output": "~/.config/spicetify/Themes/Matugen/user.css"
    },
    {
      "name": "yazi",
      "template": "yazi-theme.toml",
      "output": "~/.config/yazi/theme.toml"
    },
    {
      "name": "hyprland",
      "template": "hyprland-colors.lua",
      "output": "~/.config/hypr/colors.lua",
      "reload": "hyprctl reload"
    },
    {
      "name": "rofi",
      "template": "rofi-colors.rasi",
      "output": "~/.config/rofi/colors.rasi"
    },
    {
      "_comment": "Material You colors for Neovim (NvChad base46)",
      "name": "neovim",
      "template": "nvim-theme.lua",
      "output": "~/.config/nvim/lua/themes/matugen.lua"
    }
  ],
  "components": {
    "wallpaperSelector": {
      "displayMode": "slices",
      "sliceSpacing": -30,
      "hexScrollStep": 1,
      "customPresets": {}
    }
  },
  "wallpaperMute": true,
  "pickOnlyMode": false,
  "externalWallpaperCommand": "",
  "postProcessing": [],
  "performance": {
    "imageOptimizePreset": "balanced",
    "imageOptimizeResolution": "2k",
    "videoConvertPreset": "balanced",
    "videoConvertResolution": "2k",
    "autoOptimizeImages": false,
    "autoConvertVideos": false,
    "imageTrashDays": 7,
    "videoTrashDays": 7,
    "autoDeleteImageTrash": false,
    "autoDeleteVideoTrash": false
  }
}
